# PostgreSQL, основное хранилище бота.
# Локально:
# DATABASE_URL=postgresql+psycopg://hmmls_bot:hmmls_dev_password@localhost:5432/hmmls_warehouse_dev
# На сервере укажи боевые user/password/host/database.
DATABASE_URL=

# Google Sheets нужны только для разовой миграции старых данных в PostgreSQL.
# После успешного запуска scripts/migrate_google_sheets_to_postgres.py
# обычная работа бота от этих переменных не зависит.
GOOGLE_CREDENTIALS_PATH=google_credentials.json
PAYROLL_GOOGLE_SHEET_ID=
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET_NAME=Оприходование
OPERATIONS_GOOGLE_SHEET_ID=
